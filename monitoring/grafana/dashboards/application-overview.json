{
  "uid": "transcendence-overview",
  "title": "Transcendence — Visão Geral",
  "tags": ["transcendence", "overview"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Serviços Online",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "Online", "color": "green" }, "0": { "text": "Offline", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [
        {
          "expr": "sum(up)",
          "legendFormat": "Targets",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Spring Boot API",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "Online", "color": "green" }, "0": { "text": "Offline", "color": "red" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "up{job=\"spring-boot-api\"}", "legendFormat": "API", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Python Service",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "Online", "color": "green" }, "0": { "text": "Offline", "color": "red" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "up{job=\"python-profile-service\"}", "legendFormat": "Python", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "PostgreSQL",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "Online", "color": "green" }, "0": { "text": "Offline", "color": "red" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "up{job=\"postgresql\"}", "legendFormat": "PostgreSQL", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requisições HTTP por Segundo (API)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
        }
      },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot-api\"}[1m])", "legendFormat": "{{ method }} {{ uri }} ({{ status }})", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latência HTTP p95 (API)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] }
        }
      },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"spring-boot-api\"}[5m]))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{job=\"spring-boot-api\"}[5m]))", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Erros HTTP 5xx (API)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot-api\",status=~\"5..\"}[5m])", "legendFormat": "{{ method }} {{ uri }}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Requisições FastAPI (Python Service)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        { "expr": "rate(http_requests_total{job=\"python-profile-service\"}[1m])", "legendFormat": "{{ method }} {{ handler }} ({{ status_code }})", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource"
      }
    ]
  }
}
