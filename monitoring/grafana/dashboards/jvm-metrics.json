{
  "uid": "transcendence-jvm",
  "title": "Transcendence — JVM / Spring Boot",
  "tags": ["transcendence", "jvm", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Heap JVM (%)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "minVizWidth": 75,
        "minVizHeight": 75
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }]
          }
        }
      },
      "targets": [
        {
          "expr": "(jvm_memory_used_bytes{area=\"heap\",job=\"spring-boot-api\"} / jvm_memory_max_bytes{area=\"heap\",job=\"spring-boot-api\"}) * 100",
          "legendFormat": "{{ id }}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Threads Ativas",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 200 }] }
        }
      },
      "targets": [{ "expr": "jvm_threads_live_threads{job=\"spring-boot-api\"}", "legendFormat": "Threads", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Classes Carregadas",
      "gridPos": { "x": 6, "y": 3, "w": 6, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "jvm_classes_loaded_classes{job=\"spring-boot-api\"}", "legendFormat": "Classes", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "process_uptime_seconds{job=\"spring-boot-api\"}", "legendFormat": "Uptime", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "CPU Process (%)",
      "gridPos": { "x": 12, "y": 3, "w": 6, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] }
        }
      },
      "targets": [{ "expr": "process_cpu_usage{job=\"spring-boot-api\"}", "legendFormat": "CPU", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Conexões DB Pool",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 10 }] }
        }
      },
      "targets": [{ "expr": "hikaricp_connections_active{job=\"spring-boot-api\"}", "legendFormat": "Ativas", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "DB Pool — Pending",
      "gridPos": { "x": 18, "y": 3, "w": 6, "h": 3 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "hikaricp_connections_pending{job=\"spring-boot-api\"}", "legendFormat": "Pendentes", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memória JVM — Heap vs Non-Heap",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        { "expr": "jvm_memory_used_bytes{area=\"heap\",job=\"spring-boot-api\"}", "legendFormat": "Heap Usado — {{ id }}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "jvm_memory_used_bytes{area=\"nonheap\",job=\"spring-boot-api\"}", "legendFormat": "Non-Heap — {{ id }}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "GC — Pause Time (rate)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_sum{job=\"spring-boot-api\"}[5m])", "legendFormat": "{{ action }} {{ cause }}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Threads JVM",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        { "expr": "jvm_threads_live_threads{job=\"spring-boot-api\"}", "legendFormat": "Live", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "jvm_threads_daemon_threads{job=\"spring-boot-api\"}", "legendFormat": "Daemon", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "jvm_threads_peak_threads{job=\"spring-boot-api\"}", "legendFormat": "Peak", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HikariCP — Pool de Conexões",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        { "expr": "hikaricp_connections_active{job=\"spring-boot-api\"}", "legendFormat": "Ativas", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "hikaricp_connections_idle{job=\"spring-boot-api\"}", "legendFormat": "Idle", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "hikaricp_connections_pending{job=\"spring-boot-api\"}", "legendFormat": "Pendentes", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "expr": "hikaricp_connections{job=\"spring-boot-api\"}", "legendFormat": "Total", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      }
    ]
  }
}
